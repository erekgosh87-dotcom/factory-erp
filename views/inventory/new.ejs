<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add Inventory Roll</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <nav class="topbar">
    <div class="left">
      <a href="/">Dashboard</a>
      <a href="/production">Production</a>
      <a href="/labour">Labour</a>
      <a href="/inventory" class="active">Inventory</a>
      <a href="/tally">Tally</a>
    </div>
    <div class="right">
      <a href="/logout">Logout</a>
    </div>
  </nav>
  <main class="container">
    <h1>Add Inventory Roll</h1>
    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>
    <form method="post" action="/inventory/new" class="form">
      <div class="form-group">
        <label>Roll ID</label>
        <input type="text" name="rollId" required>
      </div>
      <div class="form-group">
        <label>Supplier</label>
        <input type="text" name="supplier" required>
      </div>
      <div class="form-group">
        <label>GSM</label>
        <input type="number" step="0.01" name="gsm" required>
      </div>
      <div class="form-group">
        <label>Width</label>
        <input type="number" step="0.01" name="width" required>
      </div>
      <div class="form-group">
        <label>Color</label>
        <input type="text" name="color" required>
      </div>
      <div class="form-group">
        <label>Quantity</label>
        <input type="number" step="0.01" name="quantity" required>
      </div>
      <button type="submit" class="btn">Save</button>
    </form>
  </main>
</body>
</html>