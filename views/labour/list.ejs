<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Labour Payments</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <nav class="topbar">
    <div class="left">
      <a href="/">Dashboard</a>
      <a href="/production">Production</a>
      <a href="/labour" class="active">Labour</a>
      <a href="/inventory">Inventory</a>
      <a href="/tally">Tally</a>
    </div>
    <div class="right">
      <label>Branch:</label>
      <select onchange="location.href='/branch/select/' + this.value;">
        <% branches.forEach(function(b) { %>
          <option value="<%= b.id %>" <%= b.id === branchId ? 'selected' : '' %>><%= b.name %></option>
        <% }); %>
      </select>
      <a href="/logout">Logout</a>
    </div>
  </nav>
  <main class="container">
    <h1>Labour Payments</h1>
    <a href="/labour/new" class="btn">Add Payment</a>
    <table class="table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Worker</th>
          <th>Amount</th>
          <th>Mode</th>
          <th>Remarks</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% payments.forEach(function(p) { %>
        <tr>
          <td><%= p.date.toISOString().split('T')[0] %></td>
          <td><%= p.worker ? p.worker.name : '' %></td>
          <td><%= p.amount.toFixed(2) %></td>
          <td><%= p.mode %></td>
          <td><%= p.remarks || '' %></td>
          <td>
            <form method="post" action="/labour/<%= p.id %>/cancel" onsubmit="return confirm('Cancel this payment?');">
              <button type="submit" class="btn btn-danger">Cancel</button>
            </form>
          </td>
        </tr>
        <% }); %>
        <% if (payments.length === 0) { %>
        <tr><td colspan="6" class="empty">No payments</td></tr>
        <% } %>
      </tbody>
    </table>
  </main>
</body>
</html>